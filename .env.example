# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- App ---
APP_NAME=smart-water-monitor
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=smart_water

# --- MQTT (Mosquitto) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=fastapi-backend
MQTT_TOPIC_SENSOR=home/+/+/sensor
MQTT_TOPIC_ALERT=home/+/+/alert
MQTT_TOPIC_STATUS=home/+/+/status

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Alert thresholds ---
ALERT_DURATION_THRESHOLD_SEC=300
